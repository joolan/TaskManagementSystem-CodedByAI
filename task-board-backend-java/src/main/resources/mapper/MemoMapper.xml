<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.taskboard.backend.mapper.MemoMapper">

    <resultMap id="MemoResultMap" type="com.taskboard.backend.model.Memo">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="content" column="content"/>
        <result property="createdBy" column="created_by"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
        
        <association property="creator" javaType="com.taskboard.backend.model.User">
            <id property="id" column="user_id"/>
            <result property="username" column="user_username"/>
            <result property="name" column="user_name"/>
        </association>
    </resultMap>

    <sql id="Base_Column_List">
        id, name, content, created_by, created_at, updated_at
    </sql>

    <sql id="Join_Column_List">
        u.id as user_id,
        u.username as user_username,
        u.name as user_name
    </sql>

    <select id="findById" resultMap="MemoResultMap">
        SELECT
            m.*,
            <include refid="Join_Column_List"/>
        FROM memos m
        LEFT JOIN users u ON m.created_by = u.id
        WHERE m.id = #{id}
    </select>

    <select id="findAll" resultMap="MemoResultMap">
        SELECT
            m.*,
            <include refid="Join_Column_List"/>
        FROM memos m
        LEFT JOIN users u ON m.created_by = u.id
        ORDER BY m.updated_at DESC
    </select>

    <select id="findByCreatedBy" resultMap="MemoResultMap">
        SELECT
            m.*,
            <include refid="Join_Column_List"/>
        FROM memos m
        LEFT JOIN users u ON m.created_by = u.id
        WHERE m.created_by = #{createdBy}
        ORDER BY m.updated_at DESC
    </select>

    <insert id="insert" parameterType="com.taskboard.backend.model.Memo" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO memos (
            name,
            content,
            created_by,
            created_at,
            updated_at
        ) VALUES (
            #{name},
            #{content},
            #{createdBy},
            #{createdAt},
            #{updatedAt}
        )
    </insert>

    <update id="update" parameterType="com.taskboard.backend.model.Memo">
        UPDATE memos
        <set>
            <if test="name != null">name = #{name},</if>
            <if test="content != null">content = #{content},</if>
            updated_at = #{updatedAt}
        </set>
        WHERE id = #{id}
    </update>

    <delete id="delete" parameterType="java.lang.Long">
        DELETE FROM memos WHERE id = #{id}
    </delete>

</mapper>

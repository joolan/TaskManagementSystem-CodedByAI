<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.taskboard.backend.mapper.TaskLogMapper">

    <resultMap id="TaskLogResultMap" type="com.taskboard.backend.model.TaskLog">
        <id property="id" column="id"/>
        <result property="actionType" column="action_type"/>
        <result property="title" column="title"/>
        <result property="content" column="content"/>
        <result property="createdAt" column="created_at"/>
        
        <!-- 关联对象 -->
        <association property="task" javaType="com.taskboard.backend.model.Task">
            <id property="id" column="task_id"/>
            <result property="title" column="task_title"/>
        </association>
        
        <association property="user" javaType="com.taskboard.backend.model.User">
            <id property="id" column="user_id"/>
            <result property="username" column="user_username"/>
            <result property="name" column="user_name"/>
        </association>
    </resultMap>

    <sql id="Base_Column_List">
        tl.id, tl.task_id, tl.user_id, tl.action_type, tl.title, tl.content, tl.created_at
    </sql>

    <sql id="Join_Column_List">
        t.id as task_id, t.title as task_title,
        u.id as user_id, u.username as user_username, u.name as user_name
    </sql>

    <select id="findById" resultMap="TaskLogResultMap">
        SELECT
            <include refid="Base_Column_List"/>,
            <include refid="Join_Column_List"/>
        FROM task_logs tl
        LEFT JOIN tasks t ON tl.task_id = t.id
        LEFT JOIN users u ON tl.user_id = u.id
        WHERE tl.id = #{id}
    </select>

    <select id="findByTaskId" resultMap="TaskLogResultMap">
        SELECT
            <include refid="Base_Column_List"/>,
            <include refid="Join_Column_List"/>
        FROM task_logs tl
        LEFT JOIN tasks t ON tl.task_id = t.id
        LEFT JOIN users u ON tl.user_id = u.id
        WHERE tl.task_id = #{taskId}
        ORDER BY tl.created_at DESC
    </select>

    <insert id="insert" parameterType="com.taskboard.backend.model.TaskLog" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO task_logs (task_id, user_id, action_type, title, content, created_at)
        VALUES (#{task.id}, #{user.id}, #{actionType}, #{title}, #{content}, #{createdAt})
    </insert>

    <delete id="delete" parameterType="java.lang.Long">
        DELETE FROM task_logs WHERE id = #{id}
    </delete>

</mapper>

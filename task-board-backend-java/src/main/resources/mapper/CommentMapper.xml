<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.taskboard.backend.mapper.CommentMapper">

    <resultMap id="CommentResultMap" type="com.taskboard.backend.model.Comment">
        <id property="id" column="id"/>
        <result property="taskId" column="task_id"/>
        <result property="userId" column="user_id"/>
        <result property="content" column="content"/>
        <result property="isAnonymous" column="is_anonymous"/>
        <result property="pinnedAt" column="pinned_at"/>
        <result property="createdAt" column="created_at"/>
        
        <association property="task" javaType="com.taskboard.backend.model.Task">
            <id property="id" column="task_id"/>
            <result property="title" column="task_title"/>
        </association>
        
        <association property="user" javaType="com.taskboard.backend.model.User">
            <id property="id" column="user_id"/>
            <result property="username" column="user_username"/>
            <result property="name" column="user_name"/>
        </association>
    </resultMap>

    <sql id="Base_Column_List">
        id, task_id, user_id, content, is_anonymous, pinned_at, created_at
    </sql>

    <sql id="Join_Column_List">
        t.title as task_title,
        u.username as user_username,
        u.name as user_name
    </sql>

    <select id="findById" resultMap="CommentResultMap">
        SELECT
            c.*,
            <include refid="Join_Column_List"/>
        FROM comments c
        LEFT JOIN tasks t ON c.task_id = t.id
        LEFT JOIN users u ON c.user_id = u.id
        WHERE c.id = #{id}
    </select>

    <select id="findAll" resultMap="CommentResultMap">
        SELECT
            c.*,
            <include refid="Join_Column_List"/>
        FROM comments c
        LEFT JOIN tasks t ON c.task_id = t.id
        LEFT JOIN users u ON c.user_id = u.id
        ORDER BY c.pinned_at DESC, c.created_at DESC
    </select>

    <select id="findByTaskId" resultMap="CommentResultMap">
        SELECT
            c.*,
            <include refid="Join_Column_List"/>
        FROM comments c
        LEFT JOIN tasks t ON c.task_id = t.id
        LEFT JOIN users u ON c.user_id = u.id
        WHERE c.task_id = #{taskId}
        ORDER BY c.pinned_at DESC, c.created_at DESC
    </select>

    <insert id="insert" parameterType="com.taskboard.backend.model.Comment" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO comments (
            task_id,
            user_id,
            content,
            is_anonymous,
            pinned_at,
            created_at
        ) VALUES (
            #{taskId},
            #{userId},
            #{content},
            #{isAnonymous},
            #{pinnedAt},
            #{createdAt}
        )
    </insert>

    <update id="update" parameterType="com.taskboard.backend.model.Comment">
        UPDATE comments
        <set>
            <if test="taskId != null">task_id = #{taskId},</if>
            <if test="userId != null">user_id = #{userId},</if>
            <if test="content != null">content = #{content},</if>
            <if test="isAnonymous != null">is_anonymous = #{isAnonymous},</if>
            <if test="pinnedAt != null">pinned_at = #{pinnedAt},</if>
        </set>
        WHERE id = #{id}
    </update>

    <delete id="delete">
        DELETE FROM comments WHERE id = #{id}
    </delete>

</mapper>
